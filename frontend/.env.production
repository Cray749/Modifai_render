# Production environment variables for Vite build.
# This file is committed to git — do NOT put secrets here.
#
# VITE_API_URL tells the frontend where the FastAPI backend lives.
# This is baked into the JS bundle at `npm run build` time.
#
# If Render assigns a different URL to the modifai-backend service,
# update this value AND the matching VITE_API_URL env var in the
# Render dashboard, then trigger a redeploy of modifai-frontend.
VITE_API_URL=https://modifai-backend.onrender.com/api/v1
